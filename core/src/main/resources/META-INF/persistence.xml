<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="national-bank-pu" transaction-type="JTA">
        <jta-data-source>j2ee_jdbc_example</jta-data-source>

        <class>com.deshan.app.banking.model.Customer</class>
        <class>com.deshan.app.banking.model.Account</class>
        <class>com.deshan.app.banking.model.Transaction</class>
        <class>com.deshan.app.banking.model.ScheduledTransaction</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
        </properties>
    </persistence-unit>
</persistence>